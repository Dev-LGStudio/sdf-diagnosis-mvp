# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...      # Settings > API > anon public
SUPABASE_SERVICE_ROLE_KEY=eyJ...          # Settings > API > service_role secret (Next.js)

# Used by Python ingestion scripts (bypasses RLS — keep secret)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...              # same as SUPABASE_SERVICE_ROLE_KEY

# ── AI APIs ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...                    # voyage-3 embeddings (1024-dim)
